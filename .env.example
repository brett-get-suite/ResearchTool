# Get a free Gemini API key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Google Ads API (for Keyword Planner — Feature 11)
# Apply at: Google Ads > Tools & Settings > API Center
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=your_customer_id_here

# Required for OAuth redirect URI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — enables city autocomplete. Falls back to OpenStreetMap if not set.
GOOGLE_MAPS_API_KEY=
